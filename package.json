{
  "name": "mission-control-hub",
  "version": "2.0.0",
  "description": "Advanced Multi-Project Dashboard connected to PostgreSQL on Coolify",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "build:js": "babel src/app.jsx --out-file public/app.js",
    "build": "npm run build:css && npm run build:js",
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@babel/cli": "^7.25.0",
    "@babel/core": "^7.25.0",
    "@babel/preset-react": "^7.24.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
